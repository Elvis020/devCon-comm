{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "target": "esnext",
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["bun", "node"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "server/**/*.ts", "lib/**/*.ts", "types/**/*.ts", "data/**/*.ts", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "app", "components", "hooks", "next-env.d.ts"]
}
